<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crop Yield Analysis Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .dark-mode { background-color: #1f2937; color: #f9fafb; }
        .dark-mode .bg-white { background-color: #374151; }
        .dark-mode .text-gray-800 { color: #f9fafb; }
        .dark-mode .bg-gray-100 { background-color: #4b5563; }
        .dark-mode table thead { background-color: #4b5563; }
        .dark-mode table tbody tr:nth-child(even) { background-color: #4b5563; }
        .dark-mode table tbody tr:hover { background-color: #6b7280; }
        table { border-collapse: collapse; width: 100%; }
        th, td { border: 1px solid #e5e7eb; padding: 8px; text-align: left; }
        th { background-color: #3b82f6; color: white; }
        tbody tr:nth-child(even) { background-color: #f9fafb; }
        tbody tr:hover { background-color: #e0f2fe; }
        .placeholder-img { background-color: #f3f4f6; color: #6b7280; text-align: center; padding: 20px; border-radius: 8px; }
    </style>
</head>
<body class="min-h-screen bg-gray-100">
    <div class="container mx-auto p-4 md:p-6">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Crop Yield Analysis Dashboard</h1>
            <button id="darkModeToggle" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg">Toggle Dark Mode</button>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-lg">
            <p class="text-gray-600 mb-4">Generated on 2025-09-12 07:21 IST. Dataset: K:/html project/cropk/yield_df.csv</p>

            <h2 class="text-2xl font-semibold text-gray-800 mb-4">Debug Information</h2>
            <p id="debug-info" class="text-red-600 mb-4">Checking for missing files...</p>

            <h2 class="text-2xl font-semibold text-gray-800 mb-4">Key Visualizations</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                <div>
                    <h3 class="text-lg font-medium">Soil pH vs Crop Yield</h3>
                    <img src="./ph_vs_yield.png" alt="Soil pH vs Crop Yield" class="w-full rounded-lg"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='block';">
                    <div class="placeholder-img" style="display:none;">Image not found: ph_vs_yield.png</div>
                </div>
                <div>
                    <h3 class="text-lg font-medium">Correlation Heatmap</h3>
                    <img src="./correlation_heatmap.png" alt="Correlation Heatmap" class="w-full rounded-lg"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='block';">
                    <div class="placeholder-img" style="display:none;">Image not found: correlation_heatmap.png</div>
                </div>
            </div>

            <h2 class="text-2xl font-semibold text-gray-800 mt-8 mb-4">Model Performance</h2>
            <div id="model-table" class="mb-4"></div>

            <h2 class="text-2xl font-semibold text-gray-800 mt-8 mb-4">Detailed Model Results</h2>
            <div id="detailed-table" class="mb-4"></div>

            <h2 class="text-2xl font-semibold text-gray-800 mt-8 mb-4">Yield Statistics by Area and Item</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="yield-stats-tables"></div>

            <h2 class="text-2xl font-semibold text-gray-800 mt-8 mb-4">Real-Time Prediction</h2>
            <div class="bg-gray-100 p-6 rounded-lg">
                <p class="text-gray-600 mb-4">Select or enter values to predict crop yield (hg/ha). Requires Flask server running at http://localhost:5000/predict.</p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700">Area</label>
                        <select id="area" class="w-full p-2 border rounded-lg">
                            <option value="">Select Area</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700">Item</label>
                        <select id="item" class="w-full p-2 border rounded-lg">
                            <option value="">Select Item</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700">Year</label>
                        <input type="number" id="year" value="2000" min="1960" max="2025" class="w-full p-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-gray-700">Avg Rain (mm/year)</label>
                        <input type="number" id="rain" value="1000" min="0" step="0.1" class="w-full p-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-gray-700">Pesticides (tonnes)</label>
                        <input type="number" id="pest" value="500" min="0" step="0.1" class="w-full p-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-gray-700">Avg Temp (°C)</label>
                        <input type="number" id="temp" value="25" min="-50" max="50" step="0.1" class="w-full p-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-gray-700">Soil pH</label>
                        <input type="number" id="ph" value="6.5" min="4.5" max="8.5" step="0.1" class="w-full p-2 border rounded-lg">
                    </div>
                </div>
                <button onclick="predictYield()" class="mt-4 bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg">Predict Yield</button>
                <p id="real-time-pred" class="mt-4 text-lg font-semibold text-green-600">Prediction will appear here</p>
                <p class="text-gray-600 mt-2">Ensure Flask server (server.py) is running for accurate predictions.</p>
            </div>
        </div>
    </div>
    <script>
        // Dark mode toggle
        document.getElementById('darkModeToggle').addEventListener('click', () => {
            document.body.classList.toggle('dark-mode');
        });

        // --- Image check (fixed with promises) ---
        const images = ['./ph_vs_yield.png', './correlation_heatmap.png'];
        let missingFiles = [];
        Promise.all(images.map(src => new Promise(resolve => {
            const img = new Image();
            img.onload = () => resolve();
            img.onerror = () => { missingFiles.push(src.replace('./', '')); resolve(); };
            img.src = src;
        }))).then(() => {
            document.getElementById('debug-info').innerText =
                missingFiles.length ? `Missing files: ${missingFiles.join(', ')}` : 'All images loaded successfully';
        });

        // --- Helper: build table from CSV ---
        function buildTable(csv) {
            const rows = csv.trim().split('\n').map(r => r.split(','));
            const table = document.createElement('table');
            table.className = 'table-auto w-full border-collapse';
            const thead = document.createElement('thead');
            thead.innerHTML = `<tr>${rows[0].map(col => `<th>${col}</th>`).join('')}</tr>`;
            table.appendChild(thead);
            const tbody = document.createElement('tbody');
            let bodyHTML = '';
            for (let i = 1; i < rows.length; i++) {
                if (rows[i].length > 1) {
                    bodyHTML += `<tr>${rows[i].map(col =>
                        `<td>${isNaN(col) ? col : parseFloat(col).toFixed(2)}</td>`).join('')}</tr>`;
                }
            }
            tbody.innerHTML = bodyHTML;
            table.appendChild(tbody);
            return table;
        }

        // Load encoder mappings
        fetch('./encoder_mappings.json')
            .then(response => {
                if (!response.ok) throw new Error('Failed to load encoder_mappings.json');
                return response.json();
            })
            .then(mappings => {
                const areaSelect = document.getElementById('area');
                const itemSelect = document.getElementById('item');
                if (!mappings.Area || !mappings.Item) throw new Error('Invalid encoder_mappings.json structure');
                Object.keys(mappings.Area).forEach(name => {
                    const option = document.createElement('option');
                    option.value = name;
                    option.textContent = name;
                    areaSelect.appendChild(option);
                });
                Object.keys(mappings.Item).forEach(name => {
                    const option = document.createElement('option');
                    option.value = name;
                    option.textContent = name;
                    itemSelect.appendChild(option);
                });
                document.getElementById('debug-info').innerText += ' | Encoder mappings loaded';
            })
            .catch(error => {
                document.getElementById('debug-info').innerText += ` | ${error.message}`;
                console.error(error);
            });

        // Load model results
        fetch('./model_results.csv')
            .then(r => { if (!r.ok) throw new Error('Failed to load model_results.csv'); return r.text(); })
            .then(csv => { document.getElementById('model-table').appendChild(buildTable(csv)); })
            .catch(error => {
                document.getElementById('model-table').innerHTML = `<p class="text-red-600">${error.message}</p>`;
                console.error(error);
            });

        // Load detailed results
        fetch('./detailed_results.csv')
            .then(r => { if (!r.ok) throw new Error('Failed to load detailed_results.csv'); return r.text(); })
            .then(csv => { document.getElementById('detailed-table').appendChild(buildTable(csv)); })
            .catch(error => {
                document.getElementById('detailed-table').innerHTML = `<p class="text-red-600">${error.message}</p>`;
                console.error(error);
            });

        // Load yield statistics
        fetch('./yield_stats.json')
            .then(r => { if (!r.ok) throw new Error('Failed to load yield_stats.json'); return r.json(); })
            .then(groups => {
                const yieldStatsDiv = document.getElementById('yield-stats-tables');
                yieldStatsDiv.innerHTML = '';
                if (!groups || groups.length === 0) throw new Error('No yield statistics data found');
                groups.forEach((group, index) => {
                    const table = document.createElement('table');
                    table.className = 'table-auto w-full border-collapse';
                    const thead = document.createElement('thead');
                    thead.innerHTML = '<tr><th>Area</th><th>Item</th><th>hg/ha_yield</th></tr>';
                    table.appendChild(thead);
                    const tbody = document.createElement('tbody');
                    let rowsHTML = '';
                    group.forEach(row => {
                        rowsHTML += `<tr><td>${row.Area}</td><td>${row.Item}</td><td>${parseFloat(row['hg/ha_yield']).toFixed(2)}</td></tr>`;
                    });
                    tbody.innerHTML = rowsHTML;
                    table.appendChild(tbody);
                    const div = document.createElement('div');
                    div.innerHTML = `<h3 class="text-lg font-medium">Group ${index + 1}</h3>`;
                    div.appendChild(table);
                    yieldStatsDiv.appendChild(div);
                });
                document.getElementById('debug-info').innerText += ' | Yield statistics loaded';
            })
            .catch(error => {
                document.getElementById('yield-stats-tables').innerHTML = `<p class="text-red-600">${error.message}</p>`;
                console.error(error);
            });

        // Prediction function
        function predictYield() {
            try {
                const area = document.getElementById('area').value;
                const item = document.getElementById('item').value;
                if (!area || !item) throw new Error('Please select Area and Item');
                const year = parseFloat(document.getElementById('year').value);
                const rain = parseFloat(document.getElementById('rain').value);
                const pest = parseFloat(document.getElementById('pest').value);
                const temp = parseFloat(document.getElementById('temp').value);
                const ph = parseFloat(document.getElementById('ph').value);

                if ([year, rain, pest, temp, ph].some(val => isNaN(val))) throw new Error('All numeric inputs must be valid numbers');
                if (year < 1960 || year > 2025) throw new Error('Year must be between 1960 and 2025');
                if (rain < 0) throw new Error('Average rainfall must be non-negative');
                if (pest < 0) throw new Error('Pesticides must be non-negative');
                if (temp < -50 || temp > 50) throw new Error('Average temperature must be between -50°C and 50°C');
                if (ph < 4.5 || ph > 8.5) throw new Error('Soil pH must be between 4.5 and 8.5');

                const data = { Area: area, Item: item, Year: year,
                    average_rain_fall_mm_per_year: rain, pesticides_tonnes: pest,
                    avg_temp: temp, soil_ph: ph };

                fetch('http://localhost:5000/predict', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data)
                })
                .then(r => { if (!r.ok) throw new Error(`Server error: ${r.status}`); return r.json(); })
                .then(data => {
                    if (data.error) throw new Error(data.error);
                    document.getElementById('real-time-pred').innerText = `Predicted Yield (hg/ha): ${data.yield.toFixed(2)}`;
                    document.getElementById('real-time-pred').className = 'mt-4 text-lg font-semibold text-green-600';
                })
                .catch(error => {
                    document.getElementById('real-time-pred').innerText = `Prediction failed: ${error.message}`;
                    document.getElementById('real-time-pred').className = 'mt-4 text-lg font-semibold text-red-600';
                });
            } catch (error) {
                document.getElementById('real-time-pred').innerText = `Prediction failed: ${error.message}`;
                document.getElementById('real-time-pred').className = 'mt-4 text-lg font-semibold text-red-600';
            }
        }
    </script>
</body>
</html>
